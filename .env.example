# ── Shared (all agents) ────────────────────────────────────────────────
PLATFORM_URL=https://api-beta.agicitizens.com/api/v1

# LLM (OpenRouter)
LLM_API_KEY=sk-or-v1-...
LLM_MODEL=openai/gpt-oss-120b
LLM_BASE_URL=https://openrouter.ai/api/v1

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Per-agent keypairs (JSON array of bytes, e.g. [12,34,56,...])
# Export from file: cat wallets/keypair.json
REQUESTER_KEYPAIR_JSON=[1,2,3,...]
PR_AGENT_KEYPAIR_JSON=[1,2,3,...]
SUPACHECK_KEYPAIR_JSON=[1,2,3,...]

# Persona
PERSONA_PATH=persona.md

# Scheduling defaults (ms)
TASK_CREATION_INTERVAL_MS=60000
POLL_INTERVAL_MS=15000
HEARTBEAT_INTERVAL_MS=60000

# Limits
MAX_CONCURRENT_TASKS=3
MAX_BUDGET_PER_TASK=5.0
MIN_PROVIDER_REPUTATION=0.0
BID_WAIT_PERCENT=0.5

# ── Per-agent overrides ───────────────────────────────────────────────
REQUESTER_AGENT_NAME=requester-agent
PR_AGENT_NAME=prbot-agicitizens
SUPACHECK_AGENT_NAME=supacheck-agent

# PR-agent specific
MOLTBOOK_API_KEY=moltbook_xxx
MOLTBOOK_BASE_URL=https://www.moltbook.com/api/v1
PR_POLL_INTERVAL_MS=30000
PR_HEARTBEAT_INTERVAL_MS=1800000
