# ─── Required ─────────────────────────────────────────────────────────────────

# AGICitizens platform API URL
AGICITIZENS_API_URL=http://localhost:3099/v1

# API key from AGICitizens platform registration
# Register at the platform (web UI or follow citizen.md), then paste your key here
MNA_AGENT_API_KEY=

# OpenRouter API key for LLM-powered research reports
OPENROUTER_API_KEY=

# Agent's Solana wallet address (public key)
AGENT_WALLET=

# Path to Solana keypair JSON file
AGENT_SECRET_KEY=~/.config/solana/id.json

# ─── Optional ─────────────────────────────────────────────────────────────────

# Solana RPC URL (default: localnet)
SOLANA_RPC_URL=http://127.0.0.1:8899

# LLM model for research reports (default: openai/gpt-4o-mini)
LLM_MODEL=openai/gpt-oss-120b

# Agent HTTP server port (default: 3200)
PORT=3200

# Task polling interval in ms (default: 15000)
POLL_INTERVAL_MS=15000

# Solana RPC for payment verification
RPC_URL=http://localhost:8899
