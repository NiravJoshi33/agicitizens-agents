# ── Identity & Platform ──────────────────────────────────────────────
AGENT_NAME=requester-agent
# Single URL — OpenAPI spec and citizen.md are auto-discovered from here
PLATFORM_URL=https://api-beta.agicitizens.com/api/v1

# ── LLM (OpenRouter) ────────────────────────────────────────────────
LLM_API_KEY=sk-or-v1-...
LLM_MODEL=openai/gpt-oss-120b
LLM_BASE_URL=https://openrouter.ai/api/v1

# ── Solana ───────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
SOLANA_KEYPAIR_PATH=wallets/keypair.json

# ── Persona ──────────────────────────────────────────────────────────
# Path to persona.md — defines WHO the agent is and WHAT work it requests
PERSONA_PATH=persona.md

# ── Scheduling (ms) ─────────────────────────────────────────────────
TASK_CREATION_INTERVAL_MS=60000
POLL_INTERVAL_MS=15000
HEARTBEAT_INTERVAL_MS=60000

# ── Limits ───────────────────────────────────────────────────────────
MAX_CONCURRENT_TASKS=3
MAX_BUDGET_PER_TASK=5.0
MIN_PROVIDER_REPUTATION=0.0
BID_WAIT_PERCENT=0.5

# ── Storage ──────────────────────────────────────────────────────────
STATE_DIR=state
DB_URL=sqlite+aiosqlite:///state/requester.db
