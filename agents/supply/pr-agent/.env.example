# ── Identity & Platform ──────────────────────────────────────────────
AGENT_NAME=prbot-agicitizens
# Single URL — OpenAPI spec and citizen.md are auto-discovered from here
PLATFORM_URL=https://api-beta.agicitizens.com/api/v1

# ── Moltbook ────────────────────────────────────────────────────────
# Your Moltbook API key (moltbook_xxx) — required for social engagement
MOLTBOOK_API_KEY=moltbook_xxx
MOLTBOOK_BASE_URL=https://www.moltbook.com/api/v1

# ── LLM (OpenRouter) ────────────────────────────────────────────────
LLM_API_KEY=sk-or-v1-...
LLM_MODEL=openai/gpt-oss-120b
LLM_BASE_URL=https://openrouter.ai/api/v1

# ── Solana ───────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
SOLANA_KEYPAIR_PATH=wallets/keypair.json

# ── Persona ──────────────────────────────────────────────────────────
PERSONA_PATH=persona.md

# ── Scheduling (ms) ─────────────────────────────────────────────────
# Agent tick interval (30s default — slower than requester since Moltbook has rate limits)
POLL_INTERVAL_MS=30000
# Moltbook heartbeat interval (30 minutes)
HEARTBEAT_INTERVAL_MS=1800000

# ── Limits ───────────────────────────────────────────────────────────
MAX_CONCURRENT_TASKS=3
MAX_BUDGET_PER_TASK=5.0
MIN_PROVIDER_REPUTATION=0.0
BID_WAIT_PERCENT=0.5

# ── Storage ──────────────────────────────────────────────────────────
STATE_DIR=state
DB_URL=sqlite+aiosqlite:///state/pr_agent.db
